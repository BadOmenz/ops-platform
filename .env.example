# Optional Docker Compose overrides for local development.
POSTGRES_DB=ops_platform
POSTGRES_USER=ops_platform
POSTGRES_PASSWORD=ops_platform
POSTGRES_PORT=5435

APP_ENV=local
APP_NAME=Ops Platform API
DATABASE_URL=postgresql+psycopg://ops_platform:ops_platform@db:5432/ops_platform
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
BACKEND_PORT=8000

DEV_AUTH_ENABLED=true
DEV_AUTH_SUBJECT=dev-user
DEV_AUTH_EMAIL=dev.user@example.com
DEV_AUTH_DISPLAY_NAME=Dev User

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=
