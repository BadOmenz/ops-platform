APP_ENV=local
APP_NAME=Ops Platform API
DATABASE_URL=postgresql+psycopg://ops_platform:ops_platform@localhost:5435/ops_platform
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
